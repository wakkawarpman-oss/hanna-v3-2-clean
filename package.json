{
  "name": "hanna-v3-2-clean",
  "version": "1.0.0",
  "description": "HANNA v3.2 — Fastify auth vertical slice",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "test": "node --test test/*.spec.js",
    "tui": "node hanna-tui.js",
    "tui:check": "node --check hanna-tui.js",
    "test:tui": "npm run tui:check && npm test",
    "security": "npm audit --production && npm test",
    "release": "npm test && npm run security && npm version patch"
  },
  "bin": {
    "hanna": "./scripts/hanna"
  },
  "dependencies": {
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "fastify": "^5.7.2",
    "fastify-plugin": "^5.0.0"
  }
}
