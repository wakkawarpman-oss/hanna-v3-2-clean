{
  "name": "hanna-v3-2-clean",
  "version": "1.0.0",
  "description": "HANNA v3.2 — Fastify auth vertical slice",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "start:prod": "node --max-old-space-size=512 app-opt.js",
    "prestart:check": "bash scripts/prestart.sh",
    "prestart:start": "bash scripts/prestart.sh --start",
    "production-readiness": "bash scripts/production-readiness.sh",
    "test": "node --test test/*.spec.js",
    "test:core": "node --test test/core-routes.spec.js test/parser.spec.js",
    "test:integration": "npm run test:core",
    "test:logic-full": "node --test test/logic-full.spec.js",
    "test:golden": "node --test test/golden.spec.js",
    "test:stress": "node --test test/stress.spec.js",
    "logic-verify": "node scripts/logic-verify.js",
    "pre-prod-check": "bash scripts/pre-prod-check.sh",
    "system-verify": "bash scripts/system-verify.sh",
    "test:smart": "node --test test/smart-search.spec.js",
    "behavioral:test": "node --test test/behavioral.spec.js",
    "test:parser": "node --test test/parser.spec.js test/parser-files.spec.js",
    "test:parser-errors": "node --test test/parser-error.spec.js",
    "test:parser-files": "node test/auto-generate-errors.js && node --test test/parser-files.spec.js",
    "test:parser-auto": "node --test test/parser-auto.spec.js",
    "test:parser:ci": "npm run test:parser-errors && npm run test:parser-files",
    "error-report": "node test/auto-generate-errors.js",
    "test:parser:watch": "node --watch --test test/parser.spec.js test/parser-files.spec.js",
    "generate:parser-report": "node test/parser-report.js",
    "test:debug": "DEBUG=1 node --test test/parser-debug.spec.js",
    "test:parser-debug": "DEBUG=1 npm run test:parser-files",
    "test:slow": "DEBUG=1 node --test test/parser-debug.spec.js",
    "debug:dump": "DEBUG=1 node test/debug-dump.js",
    "test:parser:verbose": "DEBUG=1 VERBOSE=1 npm test",
    "test:coverage": "node --test --experimental-test-coverage test/*.spec.js",
    "test:all": "npm test && python3 -m pytest -q tests/*.py",
    "tui": "node hanna-tui.js",
    "tui:ultra": "TUI_ULTRA=1 node --optimize-for-size --max-old-space-size=256 hanna-tui.js",
    "api:worker": "node app-worker.js",
    "build:prod": "npm prune --omit=dev && npm dedupe",
    "perf:monitor": "node scripts/perf-monitor.js",
    "search:smart": "node scripts/smart-search-bench.js",
    "search:cluster": "node scripts/cluster-demo.js",
    "behavioral:watch": "node scripts/behavioral-monitor.js",
    "tui:behavioral": "BEHAVIORAL=1 npm run tui:ultra",
    "calibrate": "node scripts/calibrate.js",
    "calibrate:validate": "node scripts/calibrate-validate.js",
    "calibrate:reset": "node scripts/calibrate-reset.js",
    "tui:calibrated": "CALIBRATED=1 BEHAVIORAL=1 TUI_ULTRA=1 node --optimize-for-size --max-old-space-size=256 hanna-tui.js",
    "stress:all": "bash scripts/stress-all.sh",
    "stress:api": "node scripts/stress-api.js",
    "stress:files": "node stress/large-file-marathon.js",
    "stress:cache": "node stress/cache-saturation.js",
    "stress:workers": "node stress/worker-exhaust.js",
    "stress:tui": "bash stress/tui-concurrent.sh",
    "stress:disk": "bash stress/disk-thrash.sh",
    "stress:cpu": "bash stress/cpu-throttle.sh",
    "stress:kill9": "bash stress/kill9-recovery.sh",
    "stress:24h": "bash stress/24h-marathon.sh",
    "stress:apocalypse": "bash stress/apocalypse.sh",
    "stress:report": "node scripts/stress-report.js",
    "parse:large": "node scripts/large-file-parse.js",
    "parse:batch": "node scripts/batch-parser.js",
    "bench:files": "node benchmark/file-perf.js",
    "parse:1gb": "node --max-old-space-size=1024 scripts/parse-1gb.js",
    "gen:test-files": "node scripts/gen-test-files.js",
    "tui:debug": "DEBUG=1 TUI_DEBUG=1 npm run tui",
    "tui:test": "DEBUG=1 TUI_DEBUG=1 npm run tui",
    "dev:debug": "DEBUG=1 ./scripts/hanna.sh tui",
    "tui:check": "node --check hanna-tui.js",
    "test:tui": "npm run tui:check && npm test",
    "test:contract": "npm test && python3 -m pytest -q tests/*.py",
    "health": "curl -fsS http://localhost:3000/metrics >/dev/null",
    "hanna": "./scripts/hanna.sh start",
    "security": "npm audit --omit=dev && npm test",
    "release": "npm test && npm run security && npm version patch"
  },
  "bin": {
    "hanna": "./scripts/hanna"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "fastify": "^5.7.2",
    "fastify-plugin": "^5.0.0"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "xml2js": "^0.6.2"
  }
}
