# ── HANNA OSINT Pipeline — Environment Configuration ─────────────
#
# Copy to .env and fill in your values.
# NEVER commit this file to version control.
#
# ── Core app runtime ────────────────────────────────────────────
JWT_SECRET=change-me-in-production
API_URL=http://localhost:3000
TENANT_ID=default

# ── GetContact ───────────────────────────────────────────────────
# Account: did panas (+380930075122 / didpanasrivne@gmail.com)
#
# HOW TO EXTRACT TOKEN & AES KEY:
#   1. Install GetContact on a rooted Android device/emulator
#   2. Log in with +380930075122 (didpanasrivne@gmail.com)
#   3. Run:  adb shell cat /data/data/app.source.getcontact/shared_prefs/GetContactSettingsPref.xml
#   4. Copy FINAL_KEY → GETCONTACT_AES_KEY, Token → GETCONTACT_TOKEN
#
GETCONTACT_TOKEN=
GETCONTACT_AES_KEY=

# ── Telegram Bot API ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Search4Faces ─────────────────────────────────────────────────
SEARCH4FACES_API_KEY=

# ── OpenDataBot ──────────────────────────────────────────────────
OPENDATABOT_API_KEY=

# ── Censys ───────────────────────────────────────────────────────
CENSYS_API_ID=
CENSYS_API_SECRET=

# ── Shodan ───────────────────────────────────────────────────────
SHODAN_API_KEY=

# ── NASA FIRMS ───────────────────────────────────────────────────
FIRMS_MAP_KEY=

# ── Tool path overrides ──────────────────────────────────────────
# Recommended for production: set explicit BIN overrides for every external CLI.
# For fragile tools, prefer a repo-local checkout under tools/ or a known absolute path.
# NUCLEI_BIN=nuclei
# KATANA_BIN=katana
# HTTPX_BIN=httpx
# NAABU_BIN=naabu
# BLACKBIRD_BIN=/absolute/path/to/blackbird or /repo/tools/blackbird/.venv/bin/python /repo/tools/blackbird/blackbird.py
# HOLEHE_BIN=holehe
# SUBFINDER_BIN=subfinder
# AMASS_BIN=amass
# NMAP_BIN=nmap
# SHODAN_BIN=shodan
# RECONNG_BIN=/absolute/path/to/recon-ng
# METAGOOFIL_BIN=/absolute/path/to/metagoofil or /repo/tools/metagoofil/.venv/bin/python /repo/tools/metagoofil/metagoofil.py
# EYEWITNESS_BIN=/absolute/path/to/EyeWitness or /repo/tools/EyeWitness/eyewitness-venv/bin/python /repo/tools/EyeWitness/Python/EyeWitness.py
# EYEWITNESS_CHROME_BIN=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# EYEWITNESS_CHROMEDRIVER=/opt/homebrew/bin/chromedriver
# RECONFTW_BASH=/opt/homebrew/bin/bash
# RECONFTW_CONFIG=./scripts/reconftw-hanna-macos.cfg
# RECONFTW_OUTPUT_ROOT=./Recon
# RECONFTW_RATE=80
# SPIDERFOOT_HOST=127.0.0.1
# SPIDERFOOT_PORT=5001
# SPIDERFOOT_IMAGE=local/spiderfoot:latest
# SPIDERFOOT_CONTAINER=hanna-spiderfoot
# SPIDERFOOT_DATA_DIR=./.cache/spiderfoot
# SPIDERFOOT_QUARANTINE_DIR=./.cache/spiderfoot-quarantine
# SPIDERFOOT_EXPORT_DIR=./.cache/spiderfoot-exports
# SPIDERFOOT_USECASE=Passive
# SPIDERFOOT_READY_TIMEOUT=30
# SPIDERFOOT_SCAN_WAIT_SECONDS=10
# SPIDERFOOT_POLL_INTERVAL=2

